{
  "appId": "com.packet-capture.app",
  "productName": "PowerCatch",
  "directories": {
    "output": "release"
  },
  "files": [
    "dist-electron/**",
    "dist/**"
  ],
  "mac": {
    "target": ["dmg", "zip"],
    "icon": "resources/icon.png",
    "artifactName": "${productName}-${version}-${arch}.${ext}",
    "identity": "-",
    "hardenedRuntime": false,
    "gatekeeperAssess": false
  },
  "win": {
    "target": ["nsis"],
    "icon": "resources/icon.png"
  },
  "dmg": {
    "contents": [
      { "x": 130, "y": 220 },
      { "x": 410, "y": 220, "type": "link", "path": "/Applications" }
    ]
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true
  },
  "extraResources": [
    {
      "from": "resources/",
      "to": "resources/",
      "filter": ["**/*"]
    }
  ],
  "asarUnpack": ["**/*.node"]
}
