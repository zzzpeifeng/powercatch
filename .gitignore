# ============================================================
# Electron + Vue + Vite — .gitignore
# ============================================================

# ========================
# 依赖
# ========================
node_modules/
node_modules/.cache/
.pnp/
.pnp.js

# ========================
# 构建产物
# ========================
dist/
dist-electron/
out/
release/
build/
*.tsbuildinfo

# ========================
# 环境变量 / 敏感信息
# ========================
.env
.env.*
!.env.example

# 本项目 electron-store 生成的本地配置文件（存在于项目根目录时）
settings.json
app-config.json
config.local.json

# ========================
# Electron 打包输出（二进制安装包）
# ========================
*.dmg
*.exe
*.AppImage
*.snap
*.msi
*.nsis
*.zip
*.tar.gz
*-unpacked/
latest.yml
latest-mac.yml
latest-linux.yml

# ========================
# Source maps（构建后生成）
# ========================
*.map

# ========================
# 日志
# ========================
*.log
*.log.*
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ========================
# 测试覆盖率
# ========================
coverage/
.nyc_output/
cobertura-coverage.xml

# ========================
# IDE / 编辑器配置
# ========================
.vscode/
.idea/
.cursor/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ========================
# 临时 / 个人文件
# ========================
tmp/
temp/
*.tmp
*.bak
*.backup

# ========================
# Electron 运行时生成的文件
# ========================
# http-mitm-proxy 生成的 CA 证书目录（含私钥，绝对不能提交）
.proxy-mitm/
.proxy-ca/
certs/
credentials/
ssl/
ca/
# Electron 用户数据（含本地设置、API Key 等）
# 开发时若项目根目录生成了以下文件，请取消注释：
# settings.json
# app-data.json

# ========================
# 系统文件
# ========================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ========================
# WorkBuddy 工作区
# ========================
.workbuddy/

# ========================
# 其他
# ========================
# 如果使用了 yarn pnp
.pnp/

# 如果使用 npm workspace
# packages/*/node_modules/
.http-mitm-proxy/
.pnpm-store/
